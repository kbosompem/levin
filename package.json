{
  "name": "levin",
  "displayName": "Levin",
  "description": "Browse, query, and manage Datalevin databases in VS Code",
  "version": "0.8.5",
  "publisher": "KwabenaBosompem",
  "author": {
    "name": "Kwabena Bosompem"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kbosompem/levin"
  },
  "bugs": {
    "url": "https://github.com/kbosompem/levin/issues"
  },
  "homepage": "https://github.com/kbosompem/levin#readme",
  "icon": "resources/icons/levin-128.png",
  "galleryBanner": {
    "color": "#2C3E50",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "keywords": [
