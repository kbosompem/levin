      },
      {
        "command": "levin.runAllQueries",
        "title": "Levin: Run All Queries in File",
        "icon": "$(run-all)"
      },
      {
        "command": "levin.showEntity",
        "title": "Levin: Inspect Entity"
      },
      {
        "command": "levin.refreshExplorer",
        "title": "Levin: Refresh Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "levin.exportResults",
        "title": "Levin: Export Results"
      },
      {
        "command": "levin.closeDatabase",
        "title": "Levin: Close Database"
      },
      {
        "command": "levin.createDatabase",
        "title": "Levin: Create New Database",
        "icon": "$(add)"
      },
      {
        "command": "levin.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "levin.editSchema",
        "title": "Levin: Edit Schema"
      },
      {
        "command": "levin.showTransactionPanel",
        "title": "Levin: Open Transaction Panel"
      },
      {
        "command": "levin.copyQueryAsClojure",
        "title": "Levin: Copy Query as Clojure"
      },
      {
        "command": "levin.jsonToEdn",
        "title": "Levin: Convert JSON to EDN",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "levin.runSavedQuery",
        "title": "Run Query"
      },
      {
        "command": "levin.deleteSavedQuery",
        "title": "Delete Query"
      },
      {
        "command": "levin.openSavedQuery",
        "title": "Open in Editor"
      },
      {
        "command": "levin.importData",
        "title": "Levin: Import Data"
      },
      {
        "command": "levin.browseEntities",
        "title": "Levin: Browse Entities"
      },
      {
        "command": "levin.showRelationships",
        "title": "Levin: View Relationships"
      },
      {
        "command": "levin.showRules",
        "title": "Levin: Manage Rules"
      },
      {
        "command": "levin.showOutput",
        "title": "Levin: Show Output",
        "icon": "$(output)"
      },
      {
        "command": "levin.showKvStore",
        "title": "Levin: Open Key-Value Store",
        "icon": "$(database)"
      },
      {
        "command": "levin.openKvStore",
        "title": "Open Key-Value Store",
        "icon": "$(key)"
      },
      {
        "command": "levin.createDatabaseFolder",
        "title": "Levin: Create Database Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "levin.addDatabaseToFolder",
        "title": "Add to Folder",
        "icon": "$(folder)"
      },
      {
        "command": "levin.removeDatabaseFromFolder",
        "title": "Remove from Folder"
      },
      {
        "command": "levin.moveFolderUp",
        "title": "Move Folder Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "levin.moveFolderDown",
        "title": "Move Folder Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "levin.deleteFolder",
        "title": "Delete Folder",
        "icon": "$(trash)"
      },
      {
        "command": "levin.exportFolders",
        "title": "Levin: Export Database Folders"
      },
      {
        "command": "levin.importFolders",
        "title": "Levin: Import Database Folders"
      },
      {
        "command": "levin.nlqGenerate",
        "title": "Levin: Generate Query from Natural Language",
        "icon": "$(sparkle)"
      },
      {
        "command": "levin.nlqGenerateAndRun",
        "title": "Levin: Generate and Run Query",
        "icon": "$(play)"
      },
      {
        "command": "levin.nlqRegenerate",
        "title": "Levin: Regenerate Query",
        "icon": "$(sparkle)"
      },
      {
        "command": "levin.vectorSearch",
        "title": "Levin: Vector Similarity Search",
        "icon": "$(symbol-array)"
      },
      {
        "command": "levin.trySampleDatabase",
        "title": "Levin: Try Sample Playground",
        "icon": "$(beaker)"
      },
      {
        "command": "levin.pinDatabase",
        "title": "Levin: Pin Database to This File",
        "icon": "$(pinned)"
      },
      {
        "command": "levin.paredit.forwardSexp",
        "title": "Levin: Paredit Forward S-Expression"
      },
      {
        "command": "levin.paredit.backwardSexp",
        "title": "Levin: Paredit Backward S-Expression"
      },
      {
        "command": "levin.paredit.wrapRound",
        "title": "Levin: Paredit Wrap with ( )"
      },
      {
        "command": "levin.paredit.wrapSquare",
        "title": "Levin: Paredit Wrap with [ ]"
      },
      {
        "command": "levin.paredit.slurpForward",
        "title": "Levin: Paredit Slurp Forward"
      },
      {
        "command": "levin.paredit.barfForward",
        "title": "Levin: Paredit Barf Forward"
      },
      {
        "command": "levin.paredit.raise",
        "title": "Levin: Paredit Raise"
      },
      {
        "command": "levin.paredit.splice",
        "title": "Levin: Paredit Splice"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "levin-explorer",
          "title": "Levin",
          "icon": "resources/icons/levin.svg"
        }
      ]
    },
    "views": {
      "levin-explorer": [
        {
          "id": "levin.databases",
          "name": "Databases"
        },
        {
          "id": "levin.savedQueries",
          "name": "Saved Queries"
        },
        {
          "id": "levin.history",
          "name": "Query History"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "levin.databases",
        "contents": "No databases open yet.\n[Try the Sample Playground](command:levin.trySampleDatabase) - one click builds a seeded demo database with guided query files.\n[Open Database](command:levin.openDatabase)\n[Create New Database](command:levin.createDatabase)"
      },
      {
        "view": "levin.savedQueries",
        "contents": "No saved queries yet.\nUse the **Save** CodeLens above any statement in a `.dtlv.edn` file to keep it here."
      },
      {
        "view": "levin.history",
        "contents": "No queries run yet.\nRun a query with `Ctrl+Enter` from any `.dtlv.edn` file and it will show up here."
      }
    ],
    "notebooks": [
      {
        "type": "levin-notebook",
        "displayName": "Levin Datalevin Notebook",
        "selector": [
          {
            "filenamePattern": "*.dtlvnb"
          }
        ]
      }
    ],
    "notebookRenderer": [
      {
        "id": "levin.results-renderer",
        "displayName": "Levin Results Renderer",
        "entrypoint": "./resources/notebook-renderer.js",
        "requiresMessaging": "optional",
        "mimeTypes": [
          "application/vnd.levin.results+json"
        ]
      },
      {
        "id": "levin.chart-renderer",
        "displayName": "Levin Chart Renderer",
        "entrypoint": "./resources/chart-renderer.js",
        "requiresMessaging": "never",
        "mimeTypes": [
          "application/vnd.levin.chart+json"
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "levin.gettingStarted",
        "title": "Get started with Levin",
        "description": "Query and manage Datalevin databases without leaving VS Code.",
        "steps": [
          {
            "id": "levin.playground",
            "title": "Create your sample playground",
            "description": "One click builds a seeded Mini-Northwind database - schema, data, rules, and vector embeddings included - plus five guided `.dtlv.edn` query files that teach every feature.\n[Create the Sample Playground](command:levin.trySampleDatabase)",
            "completionEvents": [
              "onCommand:levin.trySampleDatabase"
            ]
          },
          {
            "id": "levin.firstQuery",
            "title": "Run your first query",
            "description": "In `01-basics.dtlv.edn`, click inside any query and press `Ctrl+Enter` (`Cmd+Enter` on macOS). The play button in the editor title, or the CodeLens above each statement, does the same. `Cmd+Shift+Enter` runs the whole file.\n[Run Query at Cursor](command:levin.runQuery)",
            "completionEvents": [
              "onCommand:levin.runQuery"
            ]
          },
          {
            "id": "levin.pin",
            "title": "Pin a database to your file",
            "description": "The status bar shows which database a query file targets. Click it to pin a different one - just like connections in SQL tools.\n[Pin a Database](command:levin.pinDatabase)"
          },
          {
            "id": "levin.entities",
            "title": "Browse and inspect entities",
            "description": "Click any entity id in the results panel to inspect it, or browse every entity in the database.\n[Browse Entities](command:levin.browseEntities)",
            "completionEvents": [
              "onCommand:levin.browseEntities"
            ]
          },
          {
            "id": "levin.relationships",
            "title": "Explore relationships",
            "description": "References are first-class in Datalevin. The `02-relationships` playground file covers joins and pull; this panel draws the graph.\n[View Relationships](command:levin.showRelationships)",
            "completionEvents": [
              "onCommand:levin.showRelationships"
            ]
          },
          {
            "id": "levin.rules",
            "title": "Reuse logic with rules",
            "description": "Rules are named, reusable query clauses stored in the database - the sample ships a recursive org-chart rule. See `03-rules.dtlv.edn`, then manage your own.\n[Manage Rules](command:levin.showRules)",
            "completionEvents": [
              "onCommand:levin.showRules"
            ]
          },
          {
            "id": "levin.vector",
            "title": "Search by similarity",
            "description": "Every sample product has an embedding, so nearest-neighbor search is one Datalog clause. See `04-vector-search.dtlv.edn`, or use the visual panel.\n[Vector Similarity Search](command:levin.vectorSearch)",
            "completionEvents": [
              "onCommand:levin.vectorSearch"
            ]
          },
          {
            "id": "levin.transact",
            "title": "Add and shape data",
            "description": "Writes are plain data: run the `:transact` statement in `05-beyond-sql.dtlv.edn`, use the transaction panel, or evolve the schema.\n[Open Transaction Panel](command:levin.showTransactionPanel)\n[Edit Schema](command:levin.editSchema)",
            "completionEvents": [
              "onCommand:levin.showTransactionPanel"
            ]
          },
          {
            "id": "levin.save",
            "title": "Save and reuse queries",
            "description": "Keep useful queries one click away: the **Save** CodeLens above any statement adds it to the Saved Queries view, and every run lands in Query History.\n[Open Saved Queries](command:levin.savedQueries.focus)"
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "levin.runQuery",
          "when": "editorLangId == datalevin-query",
          "group": "navigation"
        },
        {
          "command": "levin.runAllQueries",
          "when": "editorLangId == datalevin-query",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "levin.openDatabase",
          "when": "view == levin.databases",
          "group": "navigation"
        },
        {
          "command": "levin.createDatabase",
          "when": "view == levin.databases",
          "group": "navigation"
        },
        {
          "command": "levin.createDatabaseFolder",
          "when": "view == levin.databases",
          "group": "navigation"
        },
        {
          "command": "levin.refreshExplorer",
          "when": "view == levin.databases",
          "group": "navigation"
        },
        {
          "command": "levin.showOutput",
          "when": "view == levin.databases",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "levin.newQuery",
          "when": "viewItem == database",
          "group": "navigation"
        },
        {
          "command": "levin.showTransactionPanel",
          "when": "viewItem == database",
          "group": "navigation"
        },
        {
          "command": "levin.editSchema",
          "when": "viewItem == database",
          "group": "navigation"
        },
        {
          "command": "levin.importData",
          "when": "viewItem == database",
          "group": "navigation"
        },
        {
          "command": "levin.vectorSearch",
          "when": "viewItem == database",
          "group": "navigation"
        },
        {
          "command": "levin.closeDatabase",
          "when": "viewItem == database",
          "group": "2_close"
        },
        {
          "command": "levin.copyPath",
          "when": "viewItem == database",
          "group": "3_copy"
        },
        {
          "command": "levin.addDatabaseToFolder",
          "when": "viewItem == database",
          "group": "4_folder"
        },
        {
          "command": "levin.removeDatabaseFromFolder",
          "when": "viewItem == database",
          "group": "4_folder"
        },
        {
          "command": "levin.moveFolderUp",
          "when": "viewItem == db-folder",
          "group": "inline"
        },
        {
          "command": "levin.moveFolderDown",
          "when": "viewItem == db-folder",
          "group": "inline"
        },
        {
          "command": "levin.deleteFolder",
          "when": "viewItem == db-folder",
          "group": "2_delete"
        },
        {
          "command": "levin.openSavedQuery",
          "when": "viewItem == savedQuery",
          "group": "navigation"
        },
        {
          "command": "levin.deleteSavedQuery",
          "when": "viewItem == savedQuery",
          "group": "2_delete"
        }
      ]
    },
    "keybindings": [
      {
        "command": "levin.openDatabase",
        "key": "ctrl+alt+l o",
        "mac": "cmd+alt+l o"
      },
      {
        "command": "levin.newQuery",
        "key": "ctrl+alt+l q",
        "mac": "cmd+alt+l q"
      },
      {
        "command": "levin.runQuery",
        "key": "ctrl+enter",
        "when": "editorLangId == datalevin-query"
      },
      {
        "command": "levin.runAllQueries",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "editorLangId == datalevin-query"
      },
      {
        "command": "levin.refreshExplorer",
        "key": "ctrl+alt+l r",
        "mac": "cmd+alt+l r"
      },
      {
        "command": "levin.paredit.forwardSexp",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.backwardSexp",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.slurpForward",
        "key": "ctrl+alt+]",
        "mac": "cmd+alt+]",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.barfForward",
        "key": "ctrl+alt+[",
        "mac": "cmd+alt+[",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.wrapRound",
        "key": "ctrl+alt+w",
        "mac": "cmd+alt+w",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.wrapSquare",
        "key": "ctrl+alt+shift+w",
        "mac": "cmd+alt+shift+w",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.raise",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      },
      {
        "command": "levin.paredit.splice",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus && editorLangId == datalevin-query"
      }
    ],
    "languages": [
      {
        "id": "datalevin-query",
        "aliases": [
          "Datalevin Query",
          "dtlv"
        ],
        "extensions": [
          ".dtlv.edn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "datalevin-query",
        "scopeName": "source.datalevin",
        "path": "./syntaxes/datalevin-query.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Levin",
      "properties": {
        "levin.dtlvPath": {
          "type": "string",
          "default": "dtlv",
          "description": "Path to dtlv executable (default assumes it's in PATH)"
        },
        "levin.bbPath": {
          "type": "string",
          "default": "",
          "description": "Path to the levin-bb binary (custom babashka build with datalevin + core.logic). Empty = auto-detect: bundled bin/levin-bb, then levin-bb on PATH. Falls back to dtlv when not found."
        },
        "levin.queryHistorySize": {
          "type": "number",
          "default": 100,
          "description": "Number of queries to keep in history"
        },
        "levin.resultPageSize": {
          "type": "number",
          "default": 50,
          "description": "Default page size for query results"
        },
        "levin.recentDatabases": {
          "type": "array",
          "default": [],
          "description": "Recently opened database paths"
        }
      }
    },
    "configurationDefaults": {
      "[datalevin-query]": {
        "editor.formatOnSave": false,
        "editor.defaultFormatter": "kaybosompem.levin"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run copy-nlq-scripts && npm run bundle-chart-renderer",
    "bundle-chart-renderer": "cat node_modules/vega/build/vega.min.js node_modules/vega-lite/build/vega-lite.min.js node_modules/vega-embed/build/vega-embed.min.js resources/chart-renderer-src.js > resources/chart-renderer.js",
    "copy-nlq-scripts": "mkdir -p out/nlq && cp src/nlq/*.py out/nlq/",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.55.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "ovsx": "^0.8.3",
    "typescript": "^5.3.2",
    "vega-embed": "^7.1.0"
  },
  "dependencies": {
    "edn-data": "^1.1.2"
  }
}
